# Variables para despliegue en EC2 (copiar a .env en el servidor)
# cp deploy/env.example .env

# Subdominio completo (debe coincidir con Route 53 y Certbot)
DOMAIN=actas.tu-dominio.com

# URL pública de la app (normalmente https + DOMAIN)
APP_PUBLIC_BASE_URL=https://actas.tu-dominio.com

# Contraseña de PostgreSQL (generar una segura)
POSTGRES_PASSWORD=cambiar_por_password_seguro

# Clave API para Power Automate / integraciones
APP_API_KEY=demo-api-key-heredia

# Perfil Spring Boot en Docker
SPRING_PROFILES_ACTIVE=docker
